# Copy this file to .env and fill real provider credentials.
# Never publish .env or client secrets in the frontend.

NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
FRONTEND_ALLOWED_ORIGIN=http://localhost:3000
COOKIE_SECRET=change-this-long-random-string
COOKIE_DOMAIN=
COOKIE_SAME_SITE=Lax
COOKIE_SECURE=false
DATA_DIR=backend/data
ADMIN_ACCOUNT_IDS=
SUPPORT_ACCOUNT_IDS=
MODERATOR_ACCOUNT_IDS=

# Optional PostgreSQL persistence. If empty, backend uses backend/data/store.json locally.
DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ЕСИА / Госуслуги OAuth. Real access requires an approved ESIA integration,
# registered information system, certificate/signature setup and exact scopes.
# Add this callback URL in the ESIA integration settings:
# http://localhost:3000/api/auth/esia/callback
ESIA_CLIENT_ID=
ESIA_CLIENT_SECRET=
ESIA_REDIRECT_URI=http://localhost:3000/api/auth/esia/callback
ESIA_SCOPE=openid fullname mobile email
ESIA_AUTH_URL=https://esia.gosuslugi.ru/aas/oauth2/ac
ESIA_TOKEN_URL=https://esia.gosuslugi.ru/aas/oauth2/te
ESIA_USERINFO_URL=

# Payments / SBP. Start with mock until a legal entity and provider cabinet exist.
# For YooKassa SBP set PAYMENT_PROVIDER=yookassa and fill YOOKASSA_* on backend only.
PAYMENT_PROVIDER=mock
PAYMENT_PRIMARY_BANK=yookassa_sbp
PAYMENT_MERCHANT_ID=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_MOCK_AUTO_CONFIRM=true

# YooKassa credentials, filled only on backend hosting after contract/shop activation.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3

# T-Bank credentials, filled only on the backend hosting after contract approval.
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=

# SMS provider credentials. Use textbelt/textbelt for a limited free demo gateway.
SMS_PROVIDER=textbelt
SMS_API_KEY=textbelt
SMS_SENDER=Dela Ryadom

# Web Push / PWA notifications. Leave empty to auto-generate and persist backend-owned VAPID keys.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# File storage. Use private S3-compatible storage in production; never store secrets in frontend files.
# Backend issues short presigned PUT/GET URLs and checks task/support/admin access before download.
FILE_STORAGE_PROVIDER=local-disabled
S3_ENDPOINT=
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional only for storage providers that expose a custom public CDN. Leave empty for private task photos.
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
