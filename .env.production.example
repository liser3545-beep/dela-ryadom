NODE_ENV=production
PORT=3000

# Public HTTPS address of the backend/site.
PUBLIC_BASE_URL=https://your-domain.example

# If frontend and backend are on different domains, put the frontend origin here.
# Multiple origins are separated by comma.
FRONTEND_ALLOWED_ORIGIN=https://your-domain.example

COOKIE_SECRET=replace-with-64-random-characters
COOKIE_DOMAIN=
COOKIE_SAME_SITE=None
COOKIE_SECURE=true
DATA_DIR=backend/data
ADMIN_ACCOUNT_IDS=
SUPPORT_ACCOUNT_IDS=
MODERATOR_ACCOUNT_IDS=

DATABASE_URL=postgres://user:password@host:5432/dela_ryadom
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

ESIA_CLIENT_ID=
ESIA_CLIENT_SECRET=
ESIA_REDIRECT_URI=https://your-domain.example/api/auth/esia/callback
ESIA_SCOPE=openid fullname mobile email
ESIA_AUTH_URL=https://esia.gosuslugi.ru/aas/oauth2/ac
ESIA_TOKEN_URL=https://esia.gosuslugi.ru/aas/oauth2/te
ESIA_USERINFO_URL=

# Payments / SBP. Keep mock until the company/sole proprietor account and YooKassa
# cabinet are approved. For production, use real values only in hosting env vars.
PAYMENT_PROVIDER=yookassa
PAYMENT_PRIMARY_BANK=yookassa_sbp
PAYMENT_MERCHANT_ID=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_MOCK_AUTO_CONFIRM=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=

SMS_PROVIDER=disabled
SMS_API_KEY=
SMS_SENDER=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.example

FILE_STORAGE_PROVIDER=s3
S3_ENDPOINT=
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Keep task photos private. Backend signs GET URLs after access checks; do not rely on a public bucket.
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
